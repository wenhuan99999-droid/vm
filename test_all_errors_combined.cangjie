// ==============================================
// 词法错误测试
// ==============================================

// L1: 无效字符 @
func test_lexical1():void {
    var a:int = 10 @ 5;
}

// L2: 无效字符 #
func test_lexical2():void {
    var b:int = 20 # 3;
}

// L3: 无效字符 $
func test_lexical3():void {
    var c:int = $100;
}

// ==============================================
// 语法错误测试
// ==============================================

// S1: 括号不匹配
func test_syntax1():void {
    if (x > 5 {
        write x;
    }
}

// S2: 无效表达式
func test_syntax2():void {
    var y:int = 10 + * 5;
}

// ==============================================
// 语义错误测试
// ==============================================

// E1: 引用未定义变量
func test_semantic1():void {
    write undefined_var;
}

// E2: 重复声明变量
func test_semantic2():void {
    var x:int = 10;
    var x:int = 20;
}

// E3: 调用未定义函数
func test_semantic3():void {
    var result:int = non_existent_func(5);
}

// ==============================================
// 主函数 - 不调用任何错误函数，只输出测试标记
// ==============================================
main() {
    write 100;  // 测试开始标记
    write 999;  // 测试结束标记
}
