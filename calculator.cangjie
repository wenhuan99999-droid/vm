// 交互式计算器程序
// 支持计算阶乘和判断奇偶性
main(){
    var num:int;
    var result:int;
    var temp:int;
    
    // 测试取模运算
    num = 7;
    result = num % 2;
    write result;
    
    num = 8;
    result = num % 2;
    write result;
    
    // 计算5的阶乘
    result = 1;
    temp = 1;
    while(temp <= 5){
        result = result * temp;
        temp = temp + 1;
    }
    write result;
}