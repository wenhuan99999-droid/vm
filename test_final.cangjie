var g_var:int = 100;
var g_arr[3]:int;

// 功能2: 不同函数可以有相同变量名
func func1(x:int):int {
    var local:int = x + 1;
    return local;
}

func func2(x:int):int {
    var local:int = x * 2;
    return local;
}

// 功能1: switch语句
func test_switch(n:int):int {
    var result:int;
    switch(n) {
        case 1: result = 100;
        case 2: result = 200;
        case 3: result = 300;
        case 4: result = 400;
        default: result = 999;
    }
    return result;
}

// 功能7: 一维数组
func fill_array():void {
    g_arr[0] = 1;
    g_arr[1] = 2;
    g_arr[2] = 3;
}

main() {
    // 功能6: 多变量声明
    var a:int, b:int = 10;
    
    write 1000;  // 测试开始标记
    
    // 测试功能5: 全局变量
    write g_var;           // 应输出 100
    
    // 测试功能3,4: 带参数和返回值的函数
    write func1(5);        // 应输出 6
    write func2(5);        // 应输出 10
    
    // 测试功能1: switch语句
    write test_switch(1);  // case 1 → 输出100
    write test_switch(2);  // case 2 → 输出200
    write test_switch(3);  // case 3 → 输出300
    write test_switch(4);  // case 4 → 输出400
    write test_switch(100);  // default → 输出999
    
    // 测试功能7: 数组
    fill_array();
    write g_arr[0];        // 应输出 1
    write g_arr[1];        // 应输出 2
    
    // 测试功能1: do-while
    var k:int = 0;
    do {
        write k;           // 应输出 0, 1
        k = k + 1;
    } while (k < 2);
    
    // 测试功能2: 不同函数的同名变量不冲突
    a = func1(9);          // a = 10
    write a;               // 应输出 10
    
    // 测试关系运算符
    var x:int = 5;
    if (x < 10 && x > 0) {
        write 1;           // 应输出 1 (真)
    }
    if (x > 10 || x < 0) {
        write 2;           // 不应输出
    }
    
    write 9999;  // 测试结束标记
}
